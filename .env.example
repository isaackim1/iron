# Iron — Supabase configuration (copy to .env and fill in; .env is gitignored)
#
# Both values come from your Supabase project: Project Settings → API.
# For a local stack (`npx supabase start`) they are printed by the CLI.
# The EXPO_PUBLIC_ prefix makes them available in app code; the anon key is
# safe to ship in the client — Row Level Security is the actual boundary.
#
# Leave both unset to run Iron in local demo mode (seeded mock data, no
# backend) — the app must never crash because these are missing.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
